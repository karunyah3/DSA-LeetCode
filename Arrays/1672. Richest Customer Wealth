class Solution {
    public int maximumWealth(int[][] accounts) {
        int wealth=0;
        for(int i=0;i<accounts.length;i++){
            int currentsum=0;
            for(int j=0;j<accounts[i].length;j++){
                currentsum+=accounts[i][j];
            }
            wealth=Math.max(wealth,currentsum);
        }
         return wealth;

    }
}
